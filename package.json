{
  "name": "lirkai",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.ts",
  "scripts": {
    "dev:ui": "vite",
    "dev:worker": "wrangler dev",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply lirkai-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply lirkai-db --remote",
    "db:seed": "wrangler d1 execute lirkai-db --local --file=migrations/seed.sql",
    "db:seed:prod": "wrangler d1 execute lirkai-db --remote --file=migrations/seed.sql",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "hono": "^4.12.12",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260409.1",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "wrangler": "^4.81.0"
  }
